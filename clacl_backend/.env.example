# ─────────────────────────────────────────────────────────────────────────────
# clac.fun backend — local dev defaults
#
# For LOCAL development you only need:
#   1. Copy this file to .env
#   2. Run `pnpm dev:full`  (auto-starts PGlite at port 5433)
#
# The default DATABASE_URL below points to the bundled PGlite (WASM postgres),
# so no postgres install is required. On Render / production, override
# DATABASE_URL with the managed postgres connection string.
# ─────────────────────────────────────────────────────────────────────────────

# Local dev DB — PGlite started by `pnpm pglite` (or pnpm dev:full)
DATABASE_URL="postgresql://clacfun:clacfun@127.0.0.1:5433/clacfun?sslmode=disable"

# ── Network ──────────────────────────────────────────────────────────────────
MONAD_NETWORK=testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_WS_URL=wss://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC_URL=https://rpc.monad.xyz
MONAD_MAINNET_WS_URL=wss://rpc.monad.xyz

# ── Factory ──────────────────────────────────────────────────────────────────
MONAD_FACTORY_ADDRESS=0x4093a7D5624B854A0f5cBBbD0b751a1aCe8049eD
MONAD_FACTORY_ADDRESS_MAINNET=

# ── HTTP / CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# Throttler (per-IP rate limit)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
WS_MAX_CONNECTIONS_PER_IP=5

# Indexer tuning
MONAD_FINALITY_BLOCKS=3
MONAD_REPLAY_BLOCKS=20
MONAD_INITIAL_BACKFILL_BLOCKS=5000
MONAD_MAX_LOG_RANGE=100

# ── Admin panel ──────────────────────────────────────────────────────────────
# REPLACE THIS BEFORE GOING TO PRODUCTION
ADMIN_PANEL_PASSWORD=change-me

# ── Cloudinary (token images) ────────────────────────────────────────────────
# Sign up at https://cloudinary.com/ and paste credentials below; otherwise
# image upload from the create page will fail.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
