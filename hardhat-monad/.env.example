# ─────────────────────────────────────────────────────────────────────────────
# Hardhat / Ignition — only needed if you intend to deploy or verify contracts.
# Skip this file if you only run the frontend/backend against the already
# deployed factory.
# ─────────────────────────────────────────────────────────────────────────────

# Wallet that will sign deploy transactions. NEVER commit a real private key.
PRIVATE_KEY=

# Optional: Etherscan / Sourcify verification API key
ETHERSCAN_API_KEY=

# Treasury address — receives creation fees + per-trade protocol fee
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
